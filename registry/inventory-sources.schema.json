{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "allowlisted_roots", "reviewed_exclusions"],
  "properties": {
    "schema_version": {"const": 1},
    "allowlisted_roots": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "reviewed_exclusions": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["path", "reason"], "properties": {"path": {"type": "string", "minLength": 1}, "reason": {"type": "string", "minLength": 1}}}}
  }
}
