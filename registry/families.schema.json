{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stack.maroun.co/registry/families.schema.json",
  "title": "Stack family registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "artifact_roles", "visibility_tiers", "families"],
  "properties": {
    "schema_version": {"const": 1},
    "artifact_roles": {"type": "array", "uniqueItems": true, "items": {"enum": ["router", "workflow", "leaf", "adapter", "reference-pack", "package", "alias"]}},
    "visibility_tiers": {"type": "array", "uniqueItems": true, "items": {"enum": ["primary", "extended", "internal", "compatibility", "reference-only", "external"]}},
    "families": {"type": "array", "minItems": 11, "items": {"type": "object", "additionalProperties": false, "required": ["id", "description", "allowed_roles", "default_trust_class"], "properties": {"id": {"type": "string", "pattern": "^[a-z]+(?:-[a-z]+)*$"}, "description": {"type": "string", "minLength": 1}, "allowed_roles": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}}, "default_trust_class": {"enum": ["read-only", "local-mutation", "external-mutation", "costly", "irreversible"]}}}}
  }
}
